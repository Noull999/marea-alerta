{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "nodeVersion": "20.x",
  "regions": ["syd"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "env": {
    "DATABASE_URL": {
      "description": "PostgreSQL database URL from Neon",
      "required": true
    },
    "GOOGLE_ID": {
      "description": "Google OAuth Client ID",
      "required": true
    },
    "GOOGLE_SECRET": {
      "description": "Google OAuth Client Secret",
      "required": true
    },
    "NEXTAUTH_SECRET": {
      "description": "Secret for Auth.js (generate with: openssl rand -base64 32)",
      "required": true
    },
    "NEXTAUTH_URL": {
      "description": "Full URL of your deployed application",
      "required": true
    },
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY": {
      "description": "Public VAPID key for push notifications",
      "required": true
    },
    "VAPID_PRIVATE_KEY": {
      "description": "Private VAPID key for push notifications",
      "required": true
    },
    "INTERNAL_API_KEY": {
      "description": "Internal API key for server-to-server communication",
      "required": true
    },
    "ANTHROPIC_API_KEY": {
      "description": "Anthropic API key for Claude AI",
      "required": false
    },
    "COPERNICUS_USERNAME": {
      "description": "Copernicus username (optional)",
      "required": false
    },
    "COPERNICUS_PASSWORD": {
      "description": "Copernicus password (optional)",
      "required": false
    },
    "RESEND_API_KEY": {
      "description": "Resend email API key (optional)",
      "required": false
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    },
    {
      "source": "/:path((?!api).*)*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/dashboard",
      "permanent": false
    }
  ]
}
