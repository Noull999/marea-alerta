# ============ AUTENTICACIÓN ============
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ============ BASE DE DATOS ============
DATABASE_URL=postgresql://user:password@localhost:5432/marea_alert

# ============ APIS OCEANOGRAFICAS ============
CMEMS_USERNAME=your-cmems-email@example.com
CMEMS_PASSWORD=your-cmems-password
SENTINEL_HUB_CLIENT_ID=your-sentinel-hub-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-hub-secret
GOOGLE_EARTH_ENGINE_PROJECT_ID=your-gee-project
GOOGLE_EARTH_ENGINE_PRIVATE_KEY=your-gee-api-key
GOOGLE_EARTH_ENGINE_CLIENT_EMAIL=your-gee-email@example.com
NOAA_API_KEY=public
IOOS_API_URL=https://www.ncei.noaa.gov/api/
AVISO_FTP_HOST=ftp.nodc.noaa.gov
AVISO_FTP_USER=anonymous
AVISO_FTP_PASS=anonymous@example.com
EMODNET_WCS_URL=https://www.emodnet.eu/geonetwork/srv/wcs
HYCOM_DATA_URL=https://www.hycom.org/data/gomod
ARGO_DATA_URL=https://argo.ucsd.edu/
BIO_ORACLE_DATA_URL=ftp://ftp.univ-nantes.fr/bio-oracle/

# ============ CRON AUTOMÁTICO ============
CRON_SECRET_TOKEN=your-cron-secret-token

# ============ DESARROLLO ============
NODE_ENV=development
